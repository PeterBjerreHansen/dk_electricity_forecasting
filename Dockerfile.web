FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY pyproject.toml README.md constraints-production.txt ./
COPY src ./src
COPY app ./app
COPY scripts/container_entrypoint.py ./scripts/container_entrypoint.py

RUN python -m pip install --upgrade pip \
    && python -m pip install -c constraints-production.txt -e ".[app,aws]"

EXPOSE 8501

ENTRYPOINT ["python", "scripts/container_entrypoint.py"]
CMD ["web"]
