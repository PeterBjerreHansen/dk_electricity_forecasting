# Copy to .env for local Docker Compose or Make overrides.

EDS_START=2024-07-01
# EDS_END=YYYY-MM-DD

OPEN_METEO_START=2024-07-01
# OPEN_METEO_END=YYYY-MM-DD

FORECAST_AT_HOUR_UTC=10
MIN_TRAIN_DAYS=60
SCORE_DAYS=14
SCORE_MAX_ORIGINS=7
SCORE_HOLDOUT_DAYS=2

# Defaults publish registry defaults: last week, weighted median, and
# chronos2_lora_calendar_weather_ctx1024_v1.
# Override to publish a smaller explicit set. Example:
# PUBLISH_MODELS=same_hour_last_week median_weekday_exp_hl4_floor10_42d__median_weekend_exp_hl28_floor20_56d
# WEATHER_FEATURES_LONG_PATH=data/features/weather_open_meteo_area_hourly_long_open_meteo_previous_runs_v1.parquet

# Set to 1 to force Open-Meteo refreshes for price-only model sets.
# Daily publishing loads existing weather artifacts unless WITH_WEATHER=1.
WITH_WEATHER=0

STREAMLIT_PORT=8501
