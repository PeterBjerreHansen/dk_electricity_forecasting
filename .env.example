# Copy to .env for local Docker Compose or Make overrides.

EDS_START=2024-07-01
# EDS_END=YYYY-MM-DD

OPEN_METEO_START=2024-07-01
# OPEN_METEO_END=YYYY-MM-DD

FORECAST_AT_HOUR_UTC=10
MIN_TRAIN_DAYS=60
SCORE_DAYS=14
SCORE_MAX_ORIGINS=7
SCORE_HOLDOUT_DAYS=2

# Defaults publish registry defaults: baselines plus catboost_price_manual_v1.
# Override to publish a smaller explicit set. Example:
# PUBLISH_MODELS=same_hour_last_week rolling_median_local_hour_28d

# Set to 1 to include Open-Meteo experiment artifact refreshes in the daily job.
WITH_WEATHER=0

STREAMLIT_PORT=8501
